#include <iostream>
using namespace std;

class Node {
public:
    int data;
    Node* left;
    Node* right;

    Node(int value) {
        data = value;
        left = right = NULL;
    }
};

Node* createBST(int arr[], int start, int end) {

    if (start > end)
        return NULL;

    int mid = (start + end) / 2;

    Node* root = new Node(arr[mid]);

    root->left = createBST(arr, start, mid - 1);

    root->right = createBST(arr, mid + 1, end);

    return root;
}

void inorder(Node* root) {

    if (root == NULL)
        return;

    inorder(root->left);

    cout << root->data << " ";

    inorder(root->right);
}

int main() {

    int arr[] = {10, 20, 30, 40, 50, 60, 70};

    int n = 7;

    Node* root = createBST(arr, 0, n - 1);

    cout << "Inorder Traversal:\n";

    inorder(root);

    return 0;
}
