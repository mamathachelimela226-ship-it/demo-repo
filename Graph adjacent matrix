#include <iostream>
using namespace std;

class Graph {

    int adj[10][10];
    int vertices;

public:

    Graph(int v) {

        vertices = v;

        for(int i = 0; i < vertices; i++) {

            for(int j = 0; j < vertices; j++) {

                adj[i][j] = 0;
            }
        }
    }

    void addEdge(int u, int v) {

        adj[u][v] = 1;
        adj[v][u] = 1;
    }

    void display() {

        cout << "Adjacency Matrix:\n";

        for(int i = 0; i < vertices; i++) {

            for(int j = 0; j < vertices; j++) {

                cout << adj[i][j] << " ";
            }

            cout << endl;
        }
    }
};

int main() {

    int vertices = 5;

    Graph g(vertices);

    g.addEdge(0, 1);
    g.addEdge(0, 2);
    g.addEdge(1, 3);
    g.addEdge(2, 4);

    g.display();

    return 0;
}
