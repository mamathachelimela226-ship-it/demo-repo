#include <iostream>
#include <vector>
using namespace std;

class Graph {

    int vertices;
    vector<int>* adj;

public:

    Graph(int v) {

        vertices = v;

        adj = new vector<int>[vertices];
    }

    void addEdge(int u, int v) {

        adj[u].push_back(v);

        adj[v].push_back(u);
    }

    void display() {

        cout << "Graph Representation (Adjacency List):\n";

        for (int i = 0; i < vertices; i++) {

            cout << "Vertex " << i << " -> ";

            for (int j : adj[i]) {

                cout << j << " ";
            }

            cout << endl;
        }
    }
};

int main() {

    int v = 5;

    Graph g(v);

    // Adding Edges
    g.addEdge(0, 1);
    g.addEdge(0, 2);
    g.addEdge(1, 3);
    g.addEdge(2, 4);
    g.addEdge(3, 4);

    // Display Graph
    g.display();

    return 0;
}
