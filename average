#include <iostream>
using namespace std;

struct Node {
    int data;
    Node* next;
};

// Function to insert node at end
void insert(Node*& head, int value) {
    Node* newNode = new Node{value, nullptr};
    if (!head) {
        head = newNode;
        return;
    }
    Node* temp = head;
    while (temp->next)
        temp = temp->next;
    temp->next = newNode;
}

// Function to find average of first, middle, last
double findAverage(Node* head) {
    if (!head) return 0;

    Node* slow = head;
    Node* fast = head;
    Node* last = head;

    // Find middle using slow-fast pointer
    while (fast && fast->next) {
        slow = slow->next;
        fast = fast->next->next;
    }

    // Find last node
    while (last->next) {
        last = last->next;
    }

    int firstVal = head->data;
    int middleVal = slow->data;
    int lastVal = last->data;

    return (firstVal + middleVal + lastVal) / 3.0;
}

int main() {
    Node* head = nullptr;

    insert(head, 10);
    insert(head, 20);
    insert(head, 30);
    insert(head, 40);
    insert(head, 50);

    double avg = findAverage(head);
    cout << "Average of first, middle, last: " << avg << endl;

    return 0;
}
